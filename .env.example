## Copy this file to `.env` and adjust as needed.
## DO NOT commit your real `.env` (it will contain secrets).

# Postgres (used by Go app)
DB_HOST=localhost
DB_PORT=5433
DB_USER=notification
DB_PASSWORD=notification
DB_NAME=notification_db
DB_SSLMODE=disable

# Kafka / Redis (used by services when running on host)
KAFKA_BROKER=localhost:9092
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Telegram delivery (Bot API)
# NOTE: Telegram bots cannot send to a username unless the user starts the bot first.
# After you start a chat with your bot, set TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

